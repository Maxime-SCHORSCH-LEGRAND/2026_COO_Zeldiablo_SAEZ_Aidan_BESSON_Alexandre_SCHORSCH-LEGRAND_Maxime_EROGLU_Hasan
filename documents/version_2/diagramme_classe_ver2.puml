@startuml
'https://plantuml.com/class-diagram

class MainPerso

interface Jeu{
+evoluer(Commande commandeUser)
+etreFini(): boolean
}

class Monstre{
-pos: Position
+Monstre()
+getPos(): Postion
+deplacer()
+subirDegtat(int d)
}

abstract Personnage{
#pos: Position
#vie: int
+Personnage(int x, int y, int vie)
+getPos(): Position
+getVie(): int
subirDegtat(int d)
}

class Hero{
-pos: Position
+Hero()
+getPos(): Postion
+deplacer()
+subirDegtat(int d)
}

class Labyrinthe{
-grille: char[][]
-hero:Hero
+Labyrinth(String fichier)
+estLibre(int x, int y): boolean
+getGrille(): char[][]
+getHero(): Hero
}

class LabyrintheDessin{
-jeu: PersoJeu
+LabyrintheDessin(JeuPerso j)
+dessiner(BufferedImage image)
}

interface DessinJeu{
+dessiner((BufferedImage im)
}

class JeuPerso{
-labyrinthe: Labyrinthe
-hero: Hero
-x: int=1
-y: int=1
+JeuPerso(Labyrinthe labyrinthe)
+evoluer(Commande c)
+etreFini(): boolean
+getLabyrinthe(): labyrinthe
+getHero():  Hero
+getX(): x
+getY(): y
+attaquer(int a)
}

Hero --> Personnage
Monstre--> Personnage
Personnage --> MainPerso
Labyrinthe --> MainPerso

JeuPerso..>Jeu
LabyrintheDessin-->MainPerso
JeuPerso-->MainPerso

DessinJeu<.. LabyrintheDessin


@enduml