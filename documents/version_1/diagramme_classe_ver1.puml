class MainPerso

interface Jeu

abstract Personnage{
#pos: Position
Position getPos()
}

class Hero{
-pos: Position
+Hero()
+getPos(): Postion
+deplacer()
}

class Labyrinth{
-grille: char[][]
-hero:Hero
+Labyrinth(String fichier)
+estLibre(int x, int y): boolean
+getGrille(): char[][]
+getHero(): Hero
+
}

class LabyrinthDessin{
-jeu: PersoJeu
}

interface DessinJeu{
+dessiner((BufferedImage im)
}

class DessinPerso{
-jeu: JeuPerso
