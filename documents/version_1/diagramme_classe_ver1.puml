+getJeu(): JeuPerso
}

class JeuPerso{
}

Hero ..> Personnage
Personnage --> MainPerso
Labyrinth --> MainPerso
MainPerso ..> JeuPerso
DessinPerso..>DessinJeu
LabyrinthDessin..>DessinJeu
JeuPerso--> Jeu
JeuPerso..>Jeu


@enduml