class Jeu

interface Personnage{
+seDeplacer()
+attaquer():int
+subirDegats():int
}
class Heros{
-vie:int
+attaquer()
+seSoigner()
}
class Monstre{
-vie:int
+attaquer()
}

class Labyrinth{
